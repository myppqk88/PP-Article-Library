# Copy this file to `.env` (gitignored) and fill in your real keys.
# 工作台启动时会自动 load 这些环境变量。

# DeepSeek（用于 AI 整理 / 笔记重写）
DEEPSEEK_API_KEY=

# 阿里 Qwen
QWEN_API_KEY=

# 任意 OpenAI 兼容接口（也用作翻译的 fallback）
OPENAI_API_KEY=

# EasyScholar 期刊等级查询（在 https://www.easyscholar.cc/ 的「开放接口」拿）
EASYSCHOLAR_SECRET_KEY=
